<?php

/**
 * @file
 * Hook implementations for the hello_world module.
 */

/**
 * Implements hook_form_FORM_ID_alter() for user_login_form.
 */
function hello_world_form_user_login_form_alter(&$form, &$form_state, $form_id) {
  $form['name']['#title']       = t('Email address');
  $form['name']['#description'] = t('Enter your email address.');
  $form['name']['#type']        = 'email';
  array_unshift($form['#validate'], '_hello_world_login_email_validator');
}

/**
 * Validator: vertaalt e-mailadres naar Drupal gebruikersnaam.
 */
function _hello_world_login_email_validator($form, &$form_state) {
  $name = $form_state->getValue('name');
  if (empty($name) || strpos($name, '@') === FALSE) {
    return;
  }
  $account = user_load_by_mail($name);
  if ($account) {
    $form_state->setValue('name', $account->getAccountName());
  }
}

/**
 * Implements hook_user_update().
 */
function hello_world_user_update(\Drupal\user\UserInterface $account) {
  if (!empty($account->_is_rabbitmq_sync)) {
    return;
  }
  // Check if status changed to inactive
  if ($account->original && $account->original->isActive() && !$account->isActive()) {
    $publisher = new \Drupal\hello_world\RabbitMQ\Publisher\UserUpdatedPublisher($account, 'cancelled');
    $publisher->publish();
  } else {
    $publisher = new \Drupal\hello_world\RabbitMQ\Publisher\UserUpdatedPublisher($account, 'updated');
    $publisher->publish();
  }
}

/**
 * Implements hook_user_delete().
 */
function hello_world_user_delete(\Drupal\user\UserInterface $account) {
  if (!empty($account->_is_rabbitmq_sync)) {
    return;
  }
  $publisher = new \Drupal\hello_world\RabbitMQ\Publisher\UserUpdatedPublisher($account, 'cancelled');
  $publisher->publish();
}
