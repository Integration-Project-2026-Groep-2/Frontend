<?php

/**
 * @file
 * Hook implementations for the hello_world module.
 */

use Drupal\hello_world\RabbitMQ\Message\RegistrationChangeMessage;
use Drupal\hello_world\RabbitMQ\RabbitMQClient;
use Drupal\user\UserInterface;
use Drupal\group\Entity\Group;
use Drupal\hello_world\RabbitMQ\Publisher\CompanyPublisher;

/**
 * Implements hook_user_update().
 *
 * Stuurt een <RegistrationChange> bericht naar RabbitMQ wanneer een
 * Drupal user wordt bijgewerkt, met routing key frontend.user.updated.
 */
function hello_world_user_update(UserInterface $account) {
  // Sla systeemaccounts over (uid 0 en 1).
  if ($account->id() <= 1) {
    return;
  }

  $original = $account->original ?? NULL;

  // Gewijzigde velden bepalen door te vergelijken met de originele waarden.
  $firstName = NULL;
  $lastName  = NULL;
  $phone     = NULL;

  if ($original) {
    $newFirst = $account->hasField('field_first_name') ? $account->get('field_first_name')->value : NULL;
    $oldFirst = $original->hasField('field_first_name') ? $original->get('field_first_name')->value : NULL;
    if ($newFirst !== $oldFirst) {
      $firstName = $newFirst;
    }

    $newLast = $account->hasField('field_surname') ? $account->get('field_surname')->value : NULL;
    $oldLast = $original->hasField('field_surname') ? $original->get('field_surname')->value : NULL;
    if ($newLast !== $oldLast) {
      $lastName = $newLast;
    }

    $newPhone = $account->hasField('field_phone') ? $account->get('field_phone')->value : NULL;
    $oldPhone = $original->hasField('field_phone') ? $original->get('field_phone')->value : NULL;
    if ($newPhone !== $oldPhone) {
      $phone = $newPhone;
    }
  }

  $message = new RegistrationChangeMessage(
    email:      $account->getEmail(),
    sessionId:  uniqid('ses_', TRUE),
    changeType: 'updated',
    firstName:  $firstName,
    lastName:   $lastName,
    phone:      $phone,
  );

  $client = RabbitMQClient::fromEnv();
  try {
    $client->publish($message);
    \Drupal::logger('hello_world')->info(
      'RabbitMQ user update verstuurd voor @email', ['@email' => $account->getEmail()]
    );
  }
  catch (\RuntimeException $e) {
    \Drupal::logger('hello_world')->error(
      'RabbitMQ user update mislukt: @err', ['@err' => $e->getMessage()]
    );
  }
  finally {
    $client->disconnect();
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for user_login_form.
 *
 * Laat gebruikers inloggen met hun e-mailadres.
 */
function hello_world_form_user_login_form_alter(&$form, &$form_state, $form_id) {
  $form['name']['#title']       = t('Email address');
  $form['name']['#description'] = t('Enter your email address.');
  $form['name']['#type']        = 'email';

  array_unshift($form['#validate'], '_hello_world_login_email_validator');
}

/**
 * Validator: vertaalt e-mailadres naar Drupal gebruikersnaam.
 */
function _hello_world_login_email_validator($form, &$form_state) {
  $name = $form_state->getValue('name');

  if (empty($name) || strpos($name, '@') === FALSE) {
    return;
  }

  $account = user_load_by_mail($name);
  if ($account) {
    $form_state->setValue('name', $account->getAccountName());
  }
}

/**
 * Implements hook_group_insert().
 */
function hello_world_group_insert(Group $group) {
  if ($group->bundle() !== 'company') {
    return;
  }

  $payload = [];

  // name
  $payload['name'] = $group->hasField('field_company_name') && !$group->get('field_company_name')->isEmpty()
    ? trim($group->get('field_company_name')->value)
    : $group->label();

  // VAT (required)
  if ($group->hasField('field_vat_number') && !$group->get('field_vat_number')->isEmpty()) {
    $payload['vatNumber'] = trim($group->get('field_vat_number')->value);
  } else {
    return;
  }

  // address fields
  foreach (['field_street', 'field_house_number', 'field_postal_code', 'field_city', 'field_country'] as $field) {
    if ($group->hasField($field) && !$group->get($field)->isEmpty()) {
      $payload[$field] = trim($group->get($field)->value);
    }
  }

  // contact person
  $contact = _hello_world_get_contact_person($group);
  if ($contact) {
    $payload['email'] = $contact->getEmail();

    foreach (['field_phone_number', 'field_phone', 'phone_number'] as $phone_field) {
      if ($contact->hasField($phone_field) && !$contact->get($phone_field)->isEmpty()) {
        $payload['phone'] = trim($contact->get($phone_field)->value);
        break;
      }
    }
  }

  try {
    /** @var \Drupal\hello_world\RabbitMQ\Publisher\CompanyPublisher $publisher */
    $publisher = \Drupal::service('hello_world.company_publisher');
    $publisher->publishCompanyCreated($payload);
  }
  catch (\Exception $e) {
    \Drupal::logger('hello_world')->error('Company publish failed: @msg', ['@msg' => $e->getMessage()]);
  }
}

/**
 * Finds the first user with group role company-contact_person.
 */
function _hello_world_get_contact_person(Group $group) {
  foreach ($group->getMembers() as $membership) {
    foreach ($membership->getRoles() as $role) {
      if ($role->id() === 'company-contact_person') {
        return $membership->getUser();
      }
    }
  }
  return NULL;
}

/**
 * Normalise Belgian VAT.
 */
function _hello_world_normalize_belgian_vat(string $vat): string {
  $v = strtoupper(trim($vat));
  $v = preg_replace('/[^A-Z0-9]/', '', $v);
  if (strpos($v, 'BE') === 0) { $v = substr($v, 2); }
  $v = preg_replace('/\D/', '', $v);
  if (strlen($v) === 9) { $v = '0' . $v; }
  if (strlen($v) === 10 && $v[0] === '0') { return 'BE' . $v; }
  return '';
}

/**
 * Validate Belgian VAT structure.
 */
function _hello_world_is_valid_belgian_vat(string $normalized): bool {
  return (bool) preg_match('/^BE0[0-9]{9}$/', $normalized);
}
