<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">

<section class="jarvis-chat-section">
  <div id="jarvis-chat" class="jarvis-chat is-empty">
    <h1 class="jarvis-greeting">Hoe kan ik je helpen?</h1>
    <p class="jarvis-subtitle">AI-assistent voor Shift Festival — vraag me over deelnemers, bedrijven, registraties of systeemstatus.</p>
    <div id="jarvis-conversation" class="jarvis-conversation" aria-live="polite"></div>
    <form id="jarvis-form" class="jarvis-form">
      <textarea id="jarvis-input" name="prompt" rows="3"
                placeholder="Vraag iets aan Jarvis..." required></textarea>
      <button type="submit" id="jarvis-send">Versturen</button>
    </form>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify/dist/purify.min.js" defer></script>
