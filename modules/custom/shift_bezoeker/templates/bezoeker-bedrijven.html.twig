<section class="bedrijven-wrapper" style="background: #0d121f; padding: 100px 0;">
  <div class="container">
    <h1 style="text-align: center; margin-bottom: 50px; font-size: 56px; font-weight: 900; font-family: 'Barlow', sans-serif; color: white;">
      Onze Partners
    </h1>

    <div class="bedrijven-grid">
      {% for bedrijf in bedrijven %}
        <div class="bedrijf-card">
          <div class="bedrijf-foto-container">
            {% if bedrijf.logo %}
              <img
                src="{{ bedrijf.logo }}"
                alt="{{ bedrijf.naam }}"
                class="bedrijf-logo"
              >
            {% else %}
              <div class="bedrijf-initial" style="width: 100%; height: 180px; display:flex; align-items:center; justify-content:center; background:#1a2133; color:white; font-size:48px; border-radius:12px;">
                {{ bedrijf.naam|slice(0,1) }}
              </div>
            {% endif %}
          </div>

          <h3 style="color: white; margin: 16px 0 8px;">{{ bedrijf.naam }}</h3>

          {% if bedrijf.beschrijving %}
            {# truncate description to max 100 characters #}
            {% set desc = bedrijf.beschrijving|striptags %}
            <p style="color: #ccc;">{{ desc|length > 100 ? desc|slice(0, 100) ~ '…' : desc }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>