<div class="qr-code-wrapper" style="min-height: 100vh; padding: 32px; color: #fff;">

    {% if error %}
      <div style="margin-bottom: 20px; padding: 12px 16px; background: #7f1d1d; border-radius: 8px;">
        {{ 'Unable to generate QR code. Please contact support.'|t }}
      </div>
    {% else %}
      <div style="padding: 24px; background: #161c2e; border-radius: 12px; text-align: center;">
        <img src="{{ qr_image }}" alt="QR Code" style="width: 300px; height: 300px; display: block; margin: 0 auto 20px; background: #fff; padding: 12px; border-radius: 12px;">

        <div style="margin: 0 0 20px; text-align: left; background: #0d121f; padding: 16px; border-radius: 8px;">
          <div style="margin-bottom: 12px;"><strong>{{ 'Name'|t }}:</strong> {{ user_name }}</div>
          <div style="word-break: break-all;"><strong>{{ 'Festival Pass ID'|t }}:</strong> {{ user_uuid }}</div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
          <button type="button" onclick="window.print()" style="padding: 12px 16px; border: 0; border-radius: 8px; background: #2563eb; color: #fff; font-weight: 600; cursor: pointer;">
            {{ 'Print'|t }}
          </button>

          <form method="POST" action="{{ path('shift_bezoeker.qr_download') }}" style="margin: 0;">
            <button type="submit" style="width: 100%; padding: 12px 16px; border: 0; border-radius: 8px; background: #059669; color: #fff; font-weight: 600; cursor: pointer;">
              {{ 'Download'|t }}
            </button>
          </form>
        </div>
      </div>
    {% endif %}

    <p style="margin: 20px 0 0; text-align: center;">
      <a href="{{ path('shift_bezoeker.account') }}" style="color: #93c5fd; text-decoration: none;">{{ 'Back to Account'|t }}</a>
    </p>
</div>
