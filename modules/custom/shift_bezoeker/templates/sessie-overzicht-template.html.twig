
<div class="session-grid-wrapper" style="
    background: linear-gradient(rgba(13, 18, 31, 0.95), rgba(13, 18, 31, 0.95)),
                url('/themes/custom/shift_theme/images/event-bg.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    min-height: 100vh;
    padding: 60px 5%;
    font-family: 'Inter', sans-serif;
    color: white;
    overflow-x: hidden;">

  {# 1. Dag Navigator #}
  <div class="day-navigation-wrapper" style="display: flex; flex-direction: column; align-items: center; margin-bottom: 25px;">
    <div style="display: flex; align-items: center; gap: 15px;">
      <a href="#" style="text-decoration: none; color: #6333ea; font-size: 24px; font-weight: bold;">&#10094;</a>
      <div style="text-align: center;">
        <span style="display: block; text-transform: uppercase; letter-spacing: 2px; font-size: 10px; color: #6333ea; font-weight: 800; font-family: 'Barlow', sans-serif;">
          Dag {{ day_number|default('01') }}
        </span>
        <span style="font-size: 15px; color: #ffffff; font-weight: 600; opacity: 0.9; font-family: 'Barlow', sans-serif;">
          {{ current_date|default('22 April 2026') }}
        </span>
      </div>
      <a href="#" style="text-decoration: none; color: #6333ea; font-size: 24px; font-weight: bold;">&#10095;</a>
    </div>
    <div style="width: 130px; height: 2px; background: #6333ea; margin-top: 10px; border-radius: 2px;"></div>
  </div>

  {# 2. Titels #}
  <div style="margin-bottom: 50px; text-align: center;">
    <h1 style="font-size: 56px; font-weight: 900; margin: 0; line-height: 1.1; font-family: 'Barlow', sans-serif;">
      {% if logged_in %} Programma {% else %} Programma Overzicht {% endif %}
    </h1>
    <p style="color: #a0a5b1; font-size: 19px; margin-top: 12px; font-family: 'Inter', sans-serif;">Beleef het Shift Festival 2026.</p>
  </div>

  {# 3. De Grid #}
  <div class="session-grid-container" style="--column-count: {{ locations|length }};">
    
    {# Headers #}
    <div class="time-header" style="grid-column: 1; grid-row: 1;"></div>
    {% for location in locations %}
      <div class="timeline-header clickable-location" 
           style="grid-column: {{ loop.index + 1 }}; cursor: pointer;"
           data-id="{{ location.location_id }}"
           data-name="{{ location.room_name }}"
           data-address="{{ location.address }}"
           data-capacity="{{ location.capacity }}"
           data-status="{{ location.status }}">
        {{ location.room_name }}
      </div>
    {% endfor %}

    {# Tijdlabels en Gridlijnen #}
    {% for label in time_labels %}
      <div class="time-label" style="grid-row: {{ loop.index + 1 }}; grid-column: 1;">
        {{ label }}
      </div>
      <div class="grid-row-line" style="grid-row: {{ loop.index + 1 }};"></div>
    {% endfor %}

    {# Sessies #}
    {% for session in grid_sessions %}
      <div class="grid-session {{ session.status }}" 
           style="grid-row: {{ session.row_start }} / span {{ session.row_span }}; grid-column: {{ session.col_index }};"
           data-id="{{ session.id }}"
           data-title="{{ session.title }}"
           data-description="{{ session.description }}"
           data-time="{{ session.time }}"
           data-location="{{ locations[session.col_index - 2].room_name }}">
        
        <div>
          <h3 title="{{ session.title }}">{{ session.title }}</h3>
          <span class="time-span">{{ session.time }}</span>
        </div>

        {% if session.status == 'full' %}
          <span style="font-size: 10px; color: #ff4d4d; font-weight: 800; text-transform: uppercase;">Volzet</span>
        {% endif %}
      </div>
    {% endfor %}

  </div>

  {# 4. Modal #}
  <div class="session-modal-overlay">
    <div class="session-modal-content">
      <button class="close-modal">&times;</button>
      <div class="modal-header">
        <h2 id="modal-title">Sessie Titel</h2>
      </div>
      <div class="modal-info">
        <span id="modal-time">10:00 - 11:30</span>
        <span id="modal-location">Locatie Naam</span>
      </div>
      <div class="modal-description" id="modal-description">
        Beschrijving van de sessie komt hier te staan.
      </div>
      <div class="modal-actions">
        <button class="register-btn">Registreer voor deze sessie</button>
      </div>
    </div>
  </div>

</div>
