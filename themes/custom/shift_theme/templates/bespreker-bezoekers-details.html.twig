{{ attach_library('shift_theme/global-styling') }}

<div style="background: #0d121f; padding: 60px 5%; min-height: 100vh; color: white; font-family: 'Inter', sans-serif;">
    <h2 style="font-size: 32px; font-weight: 900; color: #6333ea; font-family: 'Barlow', sans-serif;">Bezoekerslijst</h2>
    
    <div style="background: rgba(26,31,46,0.8); border-radius: 16px; overflow: hidden; border: 1px solid rgba(99,51,234,0.2); margin-top: 20px;">
        <div style="padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.1);">
            <p style="margin: 0; color: #a0a5b1;">
                Totaal aantal inschrijvingen: 
                <strong style="color: white;">{{ totaal }} / {{ max_capaciteit }}</strong>
            </p>
        </div>

        {% if bezoekers is not empty %}
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="background: rgba(255,255,255,0.02); color: #6333ea; font-size: 11px; font-weight: 800; text-transform: uppercase;">
                        <th style="padding: 15px 20px;">Naam</th>
                        <th style="padding: 15px 20px;">Type</th>
                    </tr>
                </thead>
                <tbody>
                    {% for bezoeker in bezoekers %}
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                            <td style="padding: 15px 20px;">{{ bezoeker.naam }}</td>
                            <td style="padding: 15px 20px; color: #a0a5b1;">{{ bezoeker.type }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div style="padding: 40px; text-align: center;">
                <p style="color: #a0a5b1;">Er zijn momenteel nog geen inschrijvingen voor deze sessie.</p>
            </div>
        {% endif %}
    </div>

    <p style="margin-top: 30px;">
        <a href="/bespreker/sessies" style="color: #a0a5b1; text-decoration: none; font-weight: 800;">« TERUG NAAR OVERZICHT</a>
    </p>
</div>
