{# We laden hier de officiële styling van het thema #}
{{ attach_library('shift_theme/global-styling') }}

<div style="background: #0d121f; padding: 60px 5%; min-height: 100vh; font-family: 'Inter', sans-serif; color: white;">
    <span style="font-size: 13px; font-weight: 600; color: #a0a5b1; text-transform: uppercase; letter-spacing: 4px; font-family: 'Barlow', sans-serif;">Dashboard</span>
    <h2 style="font-size: 42px; font-weight: 900; color: #6333ea; margin: 15px 0 20px 0; font-family: 'Barlow', sans-serif;">Sprekers Portaal</h2>
    <div style="width: 50px; height: 3px; background: #6333ea; margin-bottom: 40px; border-radius: 2px;"></div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 25px;">
        
        {# Kaartje: Profiel #}
        <div style="background: rgba(26,31,46,0.8); border: 1px solid rgba(99,51,234,0.2); border-radius: 16px; padding: 30px; box-shadow: 0 8px 32px rgba(0,0,0,0.4);">
            <div style="width: 40px; height: 3px; background: #6333ea; margin-bottom: 20px;"></div>
            <h3 style="font-size: 18px; font-weight: 800; color: white; margin-bottom: 12px; font-family: 'Barlow', sans-serif;">👤 Mijn Profiel</h3>
            <p style="color: #a0a5b1; font-size: 13px; line-height: 1.7;">Beheer je gegevens en bekijk je QR-code.</p>
            <a href="/bespreker/account" style="display: inline-block; background: #6333ea; color: white; padding: 12px 25px; border-radius: 8px; font-size: 12px; font-weight: 800; text-decoration: none; letter-spacing: 2px; text-transform: uppercase;">Bekijk Account</a>
        </div>

        {# Kaartje: Sessies #}
        <div style="background: rgba(26,31,46,0.8); border: 1px solid rgba(99,51,234,0.2); border-radius: 16px; padding: 30px; box-shadow: 0 8px 32px rgba(0,0,0,0.4);">
            <div style="width: 40px; height: 3px; background: #6333ea; margin-bottom: 20px;"></div>
            <h3 style="font-size: 18px; font-weight: 800; color: white; margin-bottom: 12px; font-family: 'Barlow', sans-serif;">📅 Mijn Sessies</h3>
            <p style="color: #a0a5b1; font-size: 13px; line-height: 1.7;">Check je planning en bezoekersaantallen.</p>
            <a href="/bespreker/sessies" style="display: inline-block; background: #6333ea; color: white; padding: 12px 25px; border-radius: 8px; font-size: 12px; font-weight: 800; text-decoration: none; letter-spacing: 2px; text-transform: uppercase;">Naar Sessies</a>
        </div>

        {# Voeg hier de rest van de kaarten toe op dezelfde manier... #}

    </div>
</div>