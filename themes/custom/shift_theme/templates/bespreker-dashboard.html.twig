{# Laden van de thema-libraries voor de juiste fonts en kleuren #}
{{ attach_library('shift_theme/global-styling') }}

{# SECTIE 1: De Sprekers Hub #}
<div style="background: #0d121f; padding: 100px 5%; display: flex; gap: 60px; align-items: center; font-family: 'Inter', sans-serif;">

  {# Links: Welkomsttekst #}
  <div style="flex: 1; min-width: 280px;">
    <span style="font-size: 13px; font-weight: 600; color: #a0a5b1; text-transform: uppercase; letter-spacing: 4px; font-family: 'Barlow', sans-serif;">Dashboard</span>
    <h2 style="font-size: 42px; font-weight: 900; color: #6333ea; margin: 15px 0 20px 0; line-height: 1.2; font-family: 'Barlow', sans-serif;">Welkom,<br>{{ user_name }}</h2>
    <div style="width: 50px; height: 3px; background: #6333ea; margin-bottom: 30px; border-radius: 2px;"></div>
    
    <p style="color: rgba(255,255,255,0.7); font-size: 15px; line-height: 1.8; margin-bottom: 25px;">
      Beheer hier je volledige aanwezigheid op het Shift Festival. Bekijk je planning, beheer je materiaal-aanvragen en bekijk de feedback van je publiek na afloop.
    </p>
    
    <a href="/bespreker/account/qr" style="background: #6333ea; color: white; padding: 14px 35px; border-radius: 8px; font-size: 13px; font-weight: 800; text-decoration: none; letter-spacing: 2px; text-transform: uppercase; font-family: 'Barlow', sans-serif;">
      TOON MIJN QR-CODE
    </a>
  </div>

  {# Rechts: Grid met actieknoppen die linken naar je nieuwe pagina's #}
  <div style="flex: 1.5; display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">

      {# Kaart 1: Gelinkt naar /bespreker/sessies #}
      <div style="background: rgba(26,31,46,0.8); border: 1px solid rgba(99,51,234,0.2); border-radius: 16px; padding: 30px; box-shadow: 0 8px 32px rgba(0,0,0,0.4);">
        <div style="width: 40px; height: 3px; background: #6333ea; margin-bottom: 20px; border-radius: 2px;"></div>
        <h3 style="font-size: 18px; font-weight: 800; color: white; margin: 0 0 12px 0; font-family: 'Barlow', sans-serif;">Mijn Sessies</h3>
        <p style="color: #a0a5b1; font-size: 13px; line-height: 1.7; margin-bottom: 15px;">Check je tijden en locaties.</p>
        <a href="/bespreker/sessies" style="color: #6333ea; font-size: 12px; font-weight: 800; text-decoration: none; text-transform: uppercase; letter-spacing: 1px;">BEKIJK PLANNING →</a>
      </div>

      {# Kaart 2: Gelinkt naar /bespreker/feedback #}
      <div style="background: rgba(26,31,46,0.8); border: 1px solid rgba(99,51,234,0.2); border-radius: 16px; padding: 30px; box-shadow: 0 8px 32px rgba(0,0,0,0.4);">
        <div style="width: 40px; height: 3px; background: #6333ea; margin-bottom: 20px; border-radius: 2px;"></div>
        <h3 style="font-size: 18px; font-weight: 800; color: white; margin: 0 0 12px 0; font-family: 'Barlow', sans-serif;">Feedback</h3>
        <p style="color: #a0a5b1; font-size: 13px; line-height: 1.7; margin-bottom: 15px;">Wat vond het publiek ervan?</p>
        <a href="/bespreker/feedback" style="color: #6333ea; font-size: 12px; font-weight: 800; text-decoration: none; text-transform: uppercase; letter-spacing: 1px;">NAAR FEEDBACK →</a>
      </div>

      {# Kaart 3: Gelinkt naar /bespreker/materialen #}
      <div style="background: rgba(26,31,46,0.8); border: 1px solid rgba(99,51,234,0.2); border-radius: 16px; padding: 30px; box-shadow: 0 8px 32px rgba(0,0,0,0.4);">
        <div style="width: 40px; height: 3px; background: #6333ea; margin-bottom: 20px; border-radius: 2px;"></div>
        <h3 style="font-size: 18px; font-weight: 800; color: white; margin: 0 0 12px 0; font-family: 'Barlow', sans-serif;">Logistiek</h3>
        <p style="color: #a0a5b1; font-size: 13px; line-height: 1.7; margin-bottom: 15px;">Je gereserveerde materiaal.</p>
        <a href="/bespreker/materialen" style="color: #6333ea; font-size: 12px; font-weight: 800; text-decoration: none; text-transform: uppercase; letter-spacing: 1px;">BEKIJK LIJST →</a>
      </div>

      {# Kaart 4: Gelinkt naar /bespreker/account #}
      <div style="background: rgba(26,31,46,0.8); border: 1px solid rgba(99,51,234,0.2); border-radius: 16px; padding: 30px; box-shadow: 0 8px 32px rgba(0,0,0,0.4);">
        <div style="width: 40px; height: 3px; background: #6333ea; margin-bottom: 20px; border-radius: 2px;"></div>
        <h3 style="font-size: 18px; font-weight: 800; color: white; margin: 0 0 12px 0; font-family: 'Barlow', sans-serif;">Mijn Profiel</h3>
        <p style="color: #a0a5b1; font-size: 13px; line-height: 1.7; margin-bottom: 15px;">Pas je gegevens en bio aan.</p>
        <a href="/bespreker/account" style="color: #6333ea; font-size: 12px; font-weight: 800; text-decoration: none; text-transform: uppercase; letter-spacing: 1px;">INSTELLINGEN →</a>
      </div>

  </div>
</div>

{# SECTIE 2: Ondersteuning (In de stijl van de Locatie-sectie) #}
<div style="background: #111827; padding: 80px 5%; font-family: 'Inter', sans-serif;">
  <div style="max-width: 1200px; margin: 0 auto; background: rgba(99,51,234,0.05); border: 1px solid rgba(99,51,234,0.2); border-radius: 16px; padding: 40px; display: flex; justify-content: space-between; align-items: center;">
    <div>
      <h3 style="color: white; font-family: 'Barlow', sans-serif; margin: 0;">Hulp nodig tijdens het festival?</h3>
      <p style="color: #a0a5b1; margin: 10px 0 0 0;">Bezoek de spreker-desk in de Foyer of neem contact op met de organisatie.</p>
    </div>
    <a href="mailto:support@shiftfestival.be" style="border: 1px solid #6333ea; color: white; padding: 12px 25px; border-radius: 8px; text-decoration: none; font-size: 12px; font-weight: 800; text-transform: uppercase;">Contact Support</a>
  </div>
</div>