RABBITMQ_USER=
RABBITMQ_PASS=
RABBITMQ_HOST=
RABBITMQ_PORT=5672

FRONTEND_DB_NAME=
FRONTEND_DB_USER=
FRONTEND_DB_PASS=
FRONTEND_DB_ROOT_PASS=

# Set to 1 ONLY for local dev fresh-clone bootstrap. Container will then
# run `drush site:install standard --yes` if Drupal is not yet installed.
# NEVER set to 1 in production — install wipes the database.
ALLOW_AUTO_INSTALL=0