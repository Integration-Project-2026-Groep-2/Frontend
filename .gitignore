# Environment variables
.env

# Docker volumes (exclude web folder but include custom modules/themes)
# web/  <-- Commented out: we want to track custom code

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# Drupal core and contrib (ignore but keep custom)
web/core/
web/modules/contrib/
web/themes/contrib/
web/profiles/contrib/
web/libraries/

# Drupal specific
web/sites/*/settings.local.php
web/sites/*/files/
web/sites/default/settings.php
web/sites/default/files/

# Vendor
web/vendor/

# Keep these (your custom code):
# !web/modules/custom/
# !web/themes/custom/
